#!/bin/bash

# SPA Builder CLI
# Build and deploy Scout-powered Single Page Applications

set -e

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TEMPLATE_DIR="$SKILL_DIR/templates/vite-template"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_usage() {
  echo "SPA Builder - Build Scout-powered Single Page Applications"
  echo ""
  echo "Usage:"
  echo "  spa-builder create <project-name>    Create new project from template"
  echo "  spa-builder add component <name>    Add component to catalog"
  echo "  spa-builder add schema <name>       Add atom schema definition"
  echo "  spa-builder build                   Build to single HTML file"
  echo "  spa-builder deploy <app-slug>       Deploy to onhyper.io"
  echo ""
  echo "Options:"
  echo "  --path <dir>    Target directory for create"
  echo "  --help          Show this help message"
  echo ""
  echo "Examples:"
  echo "  spa-builder create my-crm"
  echo "  spa-builder deploy my-crm"
}

# Command: create
cmd_create() {
  local project_name="$1"
  local target_path="${2:-.}"
  
  if [[ -z "$project_name" ]]; then
    echo -e "${RED}Error: Project name required${NC}"
    echo "Usage: spa-builder create <project-name>"
    exit 1
  fi
  
  local project_path
  if [[ "$target_path" == "." ]]; then
    project_path="$project_name"
  else
    project_path="$target_path/$project_name"
  fi
  
  echo -e "${BLUE}Creating new SPA project: $project_name${NC}"
  
  # Check if template exists
  if [[ ! -d "$TEMPLATE_DIR" ]]; then
    echo -e "${RED}Error: Template not found at $TEMPLATE_DIR${NC}"
    exit 1
  fi
  
  # Copy template
  echo -e "  ${GREEN}➜${NC} Copying template files..."
  mkdir -p "$project_path"
  rsync -a --exclude='node_modules' --exclude='dist' --exclude='.git' "$TEMPLATE_DIR/" "$project_path/"
  
  # Update package.json with project name
  if command -v jq &> /dev/null; then
    jq --arg name "$project_name" '.name = $name' "$project_path/package.json" > /tmp/pkg.json && mv /tmp/pkg.json "$project_path/package.json"
  else
    # Fallback: sed replacement
    sed -i.bak "s/\"name\": \"spa-builder-template\"/\"name\": \"$project_name\"/" "$project_path/package.json"
    rm -f "$project_path/package.json.bak"
  fi
  
  echo -e "  ${GREEN}➜${NC} Created $project_path/"
  echo ""
  echo -e "${GREEN}✓ Project created successfully!${NC}"
  echo ""
  echo "Next steps:"
  echo "  cd $project_name"
  echo "  npm install"
  echo "  npm run dev"
}

# Command: add component
cmd_add_component() {
  local component_name="$1"
  
  if [[ -z "$component_name" ]]; then
    echo -e "${RED}Error: Component name required${NC}"
    echo "Usage: spa-builder add component <ComponentName>"
    exit 1
  fi
  
  # Validate PascalCase
  if [[ ! "$component_name" =~ ^[A-Z][a-zA-Z0-9]*$ ]]; then
    echo -e "${YELLOW}Warning: Component name should be PascalCase (e.g., MyButton)${NC}"
  fi
  
  echo -e "${BLUE}Adding component: $component_name${NC}"
  echo ""
  echo -e "${YELLOW}Note: This is a template for manual implementation.${NC}"
  echo "Add the following to src/components/catalog.ts:"
  echo ""
  echo "// $componentName Props Schema"
  echo "const ${component_name}PropsSchema = z.object({"
  echo "  // Define your props here"
  echo "  children: z.string().optional().describe('Child content'),"
  echo "})"
  echo ""
  echo "Then add to the catalog:"
  echo "${component_name}: {"
  echo "  props: ${component_name}PropsSchema,"
  echo "  slots: ['default'],"
  echo "  description: 'Description of $component_name',"
  echo "},"
  echo ""
  echo "Finally, implement the React component in catalog-components.tsx"
}

# Command: add schema
cmd_add_schema() {
  local schema_name="$1"
  
  if [[ -z "$schema_name" ]]; then
    echo -e "${RED}Error: Schema name required${NC}"
    echo "Usage: spa-builder add schema <schema-name>"
    exit 1
  fi
  
  # Convert to PascalCase for types
  local type_name
  type_name=$(echo "$schema_name" | sed -E 's/(^|[-_])([a-z])/\U\2/g')
  type_name="${type_name}Atom"
  
  local props_type="${type_name/Atom/Props}"
  local component_name="${type_name/Atom/}"
  
  echo -e "${BLUE}Adding schema: $schema_name${NC}"
  echo ""
  echo -e "${YELLOW}Note: This is a template for manual implementation.${NC}"
  echo "Add the following to src/schemas/index.ts:"
  echo ""
  echo "// ${schema_name^} Schema"
  echo "export interface ${type_name} {"
  echo "  id: string"
  echo "  type: '${schema_name}'"
  echo "  data: {"
  echo "    // Define your data structure here"
  echo "    title: string"
  echo "    description?: string"
  echo "  }"
  echo "  created_at?: string"
  echo "  updated_at?: string"
  echo "}"
  echo ""
  echo "export function to${component_name}Props(atom: ${type_name}): ${props_type} {"
  echo "  return {"
  echo "    title: atom.data.title,"
  echo "    description: atom.data.description,"
  echo "  }"
  echo "}"
  echo ""
  echo "Update SupportedAtom type to include the new atom."
}

# Command: build
cmd_build() {
  echo -e "${BLUE}Building SPA...${NC}"
  
  if [[ ! -f "package.json" ]]; then
    echo -e "${RED}Error: Not in a project directory. No package.json found.${NC}"
    exit 1
  fi
  
  npm run build
  
  if [[ -f "dist/index.html" ]]; then
    local size
    size=$(wc -c < dist/index.html | tr -d ' ')
    echo ""
    echo -e "${GREEN}✓ Build complete!${NC}"
    echo -e "  Output: dist/index.html ($size bytes)"
  fi
}

# Command: deploy
cmd_deploy() {
  local app_slug="$1"
  
  if [[ -z "$app_slug" ]]; then
    echo -e "${RED}Error: App slug required${NC}"
    echo "Usage: spa-builder deploy <app-slug>"
    exit 1
  fi
  
  # Check for built files
  if [[ ! -f "dist/index.html" ]]; then
    echo -e "${RED}Error: No build found. Run 'spa-builder build' first.${NC}"
    exit 1
  fi
  
  # Check for credentials
  if [[ -z "$ONHYPER_EMAIL" ]] || [[ -z "$ONHYPER_PASSWORD" ]]; then
    echo -e "${RED}Error: onhyper credentials not set${NC}"
    echo "Set environment variables:"
    echo "  export ONHYPER_EMAIL=your-email@example.com"
    echo "  export ONHYPER_PASSWORD=your-password"
    exit 1
  fi
  
  echo -e "${BLUE}Deploying to onhyper.io...${NC}"
  echo -e "  App slug: $app_slug"
  echo ""
  
  # Step 1: Authenticate
  echo -e "  ${GREEN}➜${NC} Authenticating..."
  local auth_response
  auth_response=$(curl -s -X POST "https://onhyper.io/api/auth/login" \
    -H "Content-Type: application/json" \
    -d "{\"email\":\"$ONHYPER_EMAIL\",\"password\":\"$ONHYPER_PASSWORD\"}")
  
  local token
  token=$(echo "$auth_response" | grep -o '"token":"[^"]*"' | sed 's/"token":"//;s/"$//')
  
  if [[ -z "$token" ]]; then
    echo -e "${RED}Error: Authentication failed${NC}"
    echo "Response: $auth_response"
    exit 1
  fi
  
  # Step 2: Create app
  echo -e "  ${GREEN}➜${NC} Creating app..."
  local html_content
  html_content=$(cat dist/index.html | jq -Rs '.')
  
  local app_response
  app_response=$(curl -s -X POST "https://onhyper.io/api/apps" \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d "{\"slug\":\"$app_slug\",\"name\":\"$app_slug\",\"html\":$html_content,\"css\":\"\",\"js\":\"\"}")
  
  local app_id
  app_id=$(echo "$app_response" | grep -o '"id":"[^"]*"' | head -1 | sed 's/"id":"//;s/"$//')
  
  if [[ -z "$app_id" ]]; then
    echo -e "${YELLOW}App may already exist, checking...${NC}"
    # Try to find existing app
    local apps_list
    apps_list=$(curl -s "https://onhyper.io/api/apps" -H "Authorization: Bearer $token")
    app_id=$(echo "$apps_list" | grep -o "\"id\":\"[^\"]*\"slug\":\"$app_slug\"" | head -1 | grep -o '"id":"[^"]*"' | sed 's/"id":"//;s/"$//')
  fi
  
  # Step 3: Store Scout API key secret (if provided)
  if [[ -n "$SCOUT_API_KEY" ]]; then
    echo -e "  ${GREEN}➜${NC} Storing Scout API key secret..."
    curl -s -X POST "https://onhyper.io/api/secrets" \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      -d "{\"appId\":\"$app_id\",\"name\":\"scout-atoms\",\"value\":\"$SCOUT_API_KEY\"}" > /dev/null
  fi
  
  # Step 4: Publish
  echo -e "  ${GREEN}➜${NC} Publishing..."
  curl -s -X POST "https://onhyper.io/api/apps/$app_id/publish" \
    -H "Authorization: Bearer $token" > /dev/null
  
  echo ""
  echo -e "${GREEN}✓ Deployed successfully!${NC}"
  echo -e "  URL: https://$app_slug.onhyper.io"
}

# Parse command
case "${1:-}" in
  create)
    cmd_create "$2" "$3"
    ;;
  add)
    case "${2:-}" in
      component)
        cmd_add_component "$3"
        ;;
      schema)
        cmd_add_schema "$3"
        ;;
      *)
        echo -e "${RED}Unknown add command: ${2:-}${NC}"
        echo "Use: spa-builder add component <name> or spa-builder add schema <name>"
        exit 1
        ;;
    esac
    ;;
  build)
    cmd_build
    ;;
  deploy)
    cmd_deploy "$2"
    ;;
  --help|-h|"")
    print_usage
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    print_usage
    exit 1
    ;;
esac