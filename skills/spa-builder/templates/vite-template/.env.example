# Scout Atoms API Configuration
# ================================
# For development mode only. In production, the API key is managed
# by onhyper.io and injected server-side via the proxy.

# Scout API Key (get from https://scoutos.com)
VITE_SCOUT_API_KEY=your_scout_api_key_here

# Optional: Override default behavior
# VITE_USE_PROXY=true  # Force proxy mode even in development